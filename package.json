{
  "name": "@agegr/pi-web",
  "version": "0.6.15",
  "description": "Web UI for the pi coding agent",
  "license": "MIT",
  "main": "electron/main.js",
  "piCore": {
    "dependencies": {
      "@earendil-works/pi-ai": "^0.78.0",
      "@earendil-works/pi-coding-agent": "^0.78.0"
    }
  },
  "bin": {
    "pi-web": "bin/pi-web.js"
  },
  "files": [
    "bin",
    "electron",
    ".next/standalone",
    ".next/static",
    "!.next/cache",
    "!.next/dev",
    "!.next/**/*.js.map",
    "public",
    "next.config.ts",
    "package.json"
  ],
  "scripts": {
    "dev": "next dev -p 30141",
    "build": "next build --webpack",
    "start": "next start -p 30141",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "desktop:dev": "electron . --dev-next",
    "desktop:dev:attach": "electron . --server-url=http://127.0.0.1:30141",
    "desktop:dev:inspect": "electron --inspect=9229 . --dev-next",
    "desktop:dev:attach:inspect": "electron --inspect=9229 . --server-url=http://127.0.0.1:30141",
    "desktop:build": "npm run build && electron-builder --publish never",
    "desktop:pack:mac": "npm run build && electron-builder --mac --publish never",
    "desktop:pack:win": "npm run build && electron-builder --win --publish never",
    "release": "npm version patch --no-git-tag-version && npm run build && npm publish --access public"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.78.1",
    "@earendil-works/pi-coding-agent": "^0.78.1",
    "@lobehub/icons": "^5.6.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "katex": "^0.16.47",
    "mammoth": "^1.12.0",
    "mermaid": "^11.14.0",
    "next": "16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "postcss": "^8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5"
  },
  "build": {
    "appId": "works.earendil.pi-app",
    "productName": "Pi App",
    "asar": false,
    "afterPack": "electron/builder-hooks.js",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      ".next/standalone/**/*",
      ".next/static/**/*",
      "bin/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json",
      "!.next/cache{,/**}",
      "!.next/dev{,/**}",
      "!node_modules{,/**}",
      "!node_modules/@earendil-works/pi-agent-core{,/**}",
      "!node_modules/@earendil-works/pi-ai{,/**}",
      "!node_modules/@earendil-works/pi-coding-agent{,/**}",
      "!node_modules/@earendil-works/pi-tui{,/**}",
      "!node_modules/electron{,/**}",
      "!node_modules/electron-builder{,/**}",
      "!node_modules/.cache{,/**}",
      "!**/*.map"
    ],
    "extraMetadata": {
      "piCore": {
        "dependencies": {
          "@earendil-works/pi-ai": "^0.78.0",
          "@earendil-works/pi-coding-agent": "^0.78.0"
        }
      },
      "dependencies": {}
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
